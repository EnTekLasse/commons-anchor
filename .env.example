# PostgreSQL
POSTGRES_USER=dw_admin
POSTGRES_DB=dw
POSTGRES_PASSWORD_FILE=./infra/secrets/postgres_password.secret

# Local/runtime overrides
DW_HOST=localhost
DW_PORT=5432

# Energi Data Service
ENERGIDATASERVICE_DATASET=DayAheadPrices
ENERGIDATASERVICE_PRICE_AREAS=DK1,DK2
ENERGIDATASERVICE_START=now-P2D
ENERGIDATASERVICE_END=
ENERGIDATASERVICE_LIMIT=0

# Grafana
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD_FILE=./infra/secrets/grafana_admin_password.secret

# Metabase app db (stored in Postgres)
MB_DB_TYPE=postgres
MB_DB_DBNAME=dw
MB_DB_PORT=5432
MB_DB_USER=dw_admin
MB_DB_HOST=postgres
