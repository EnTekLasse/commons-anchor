    {
      "datasource": {
        "type": "postgres",
        "uid": "postgres-dw"
      },
      "description": "Quarter-hour day-ahead prices split by price area.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepBefore",
            "lineWidth": 2,
            "pointSize": 3,
            "showPoints": "never"
          },
          "decimals": 4,
          "unit": "currencyDKK"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "max",
            "min"
          ],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "postgres-dw"
          },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT ts_utc AS \"time\", area AS metric, price_dkk_mwh AS value\nFROM mart.power_price_15min\nWHERE $__timeFilter(ts_utc)\nORDER BY ts_utc, area;",
          "refId": "A"
        }
      ],
      "title": "15-Min Power Price by Area",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "postgres-dw"
      },
      "description": "Latest quarter-hour values from curated mart table.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto"
          },
          "decimals": 4,
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 12
      },
      "id": 2,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "show": false
        },
        "showHeader": true
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "postgres-dw"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  ts_utc,\n  ts_utc AT TIME ZONE 'Europe/Copenhagen' AS ts_dk,\n  area,\n  price_dkk_mwh AS price_dkk_mwh_raw,\n  replace(replace(replace(to_char(price_dkk_mwh, 'FM999,999,999.0000'), ',', '_'), '.', ','), '_', '.') AS price_dkk_mwh_da\nFROM mart.power_price_15min\nORDER BY ts_utc DESC, area ASC\nLIMIT 50;",
          "refId": "A"
        }
      ],
      "title": "Latest 15-Min Rows",
      "type": "table"
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "postgres-dw"
      },
      "description": "Hourly municipality mean temperature from DMI Climate (step view, same style as power price).",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepBefore",
            "lineWidth": 2,
            "pointSize": 3,
            "showPoints": "never"
          },
          "decimals": 2,
          "unit": "celsius"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 22
      },
      "id": 3,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "max",
            "min"
          ],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "postgres-dw"
          },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT ts_from_utc AS \"time\", municipality_name AS metric, mean_temp_c AS value\nFROM semantic.dmi_climate_temperature_last_7d\nWHERE $__timeFilter(ts_from_utc)\nORDER BY ts_from_utc, municipality_name;",
          "refId": "A"
        }
      ],
      "title": "Hourly Mean Temperature by Municipality",
      "type": "timeseries"
    }
